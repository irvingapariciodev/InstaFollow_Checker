@page
@model InstaFollow_Checker.Web.Pages.Projects.InstaFollowChecker.InstaFollowCheckerModel
@{
    ViewData["Title"] = "InstaFollowChecker";
}
<h1 class="text-center display-4"><b>@ViewData["Title"]</b></h1>
<br />
<br />
<div class="container">
    <div class="row align-items-center g-4">

        <!-- Image -->
        <div class="col-12 col-lg-8 text-center">
            <img src="~/resources/img/instafollowchecker_summary.png"
                 class="img-fluid"
                 alt="InstaFollowChecker Plan">
        </div>

        <!-- Form -->
        <form method="post" enctype="multipart/form-data" id="uploadForm">
        <div class="col-12 col-lg-4">

            <div class="mb-4">
                <label for="followersJSONFile" class="form-label">
                    Follower Json file
                </label>
                    <input class="form-control" type="file" id="followerFile" name="followersFile">
            </div>

            <div class="mb-4">
                <label for="followingJSONFile" class="form-label">
                    Following Json file
                </label>
                    <input class="form-control" type="file" id="followingFile" name="followingFile">
            </div>

            <div class="d-grid">
                <input class="btn btn-outline-primary"
                       type="submit"
                       value="Send">
            </div>

        </div>
        </form>

    </div>
</div>

@section Scripts {

    <script>

        document.getElementById("uploadForm").addEventListener("submit", async function (e) {

            e.preventDefault();

            const followersFile = document.getElementById("followerFile").files[0];
            const followingFile = document.getElementById("followingFile").files[0];

            if (!followersFile || !followingFile) {
                alert("Please select both files.");
                return;
            }

            const formData = new FormData();
            formData.append("followersFile", followersFile);
            formData.append("followingFile", followingFile);

            try {

                const response = await fetch("https://localhost:7057/api/follow-analysis", {
                    method: "POST",
                    body: formData
                });

                if (!response.ok)
                    throw new Error("Error sending files");

                const result = await response.json();

                console.log(result);

            }
            catch (error) {
                console.error(error);
                alert("Upload failed.");
            }

        });

    </script>

}