@page
@model InstaFollow_Checker.Web.Pages.Projects.InstaFollowChecker.InstaFollowCheckerModel
@{
    ViewData["Title"] = "InstaFollowChecker";
}

<h1 class="text-center display-4"><b>@ViewData["Title"]</b></h1>

<br />
<br />

<div class="container">

    <!-- Image + Form -->
    <div class="row align-items-center g-4">

        <div class="col-12 text-center">
            <img src="~/resources/img/instafollowchecker_summary.png"
                 class="img-fluid"
                 alt="InstaFollowChecker Plan">
        </div>

        <div class="col-12">
            <form method="post" enctype="multipart/form-data" id="uploadForm">

                <div class="mb-4">
                    <label class="form-label">Followers JSON file</label>
                    <input class="form-control" type="file" id="followerFile" name="followersFile">
                </div>

                <div class="mb-4">
                    <label class="form-label">Following JSON file</label>
                    <input class="form-control" type="file" id="followingFile" name="followingFile">
                </div>

                <div class="d-grid">
                    <input class="btn btn-outline-primary" type="submit" value="Send">
                </div>

            </form>
        </div>

    </div>


    <!-- METRICS CARDS -->
    <div class="row g-4 mt-5 justify-content-center">

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card border-primary border-1 border-opacity-25 shadow-lg rounded h-100">
                <div class="card-body text-center">
                    <h5 class="card-title fs-4">Followers</h5>
                    <p class="card-text display-5" id="followersCount">0</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card border-primary border-1 border-opacity-25 shadow-lg rounded h-100">
                <div class="card-body text-center">
                    <h5 class="card-title fs-4">Following</h5>
                    <p class="card-text display-5" id="followingCount">0</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card border-primary border-1 border-opacity-25 shadow-lg rounded h-100">
                <div class="card-body text-center">
                    <h5 class="card-title fs-4">Not Following Back</h5>
                    <p class="card-text display-5" id="NotfollowingBackCount">0</p>
                </div>
            </div>
        </div>

    </div>


    <!-- TABLE -->
    <div class="row mt-5">

        <div class="col-12 col-lg-8 mx-auto">

            <div class="table-responsive">

                <table class="table table-striped table-hover">

                    <thead>
                        <tr>
                            <th class="text-center">Username</th>
                            <th class="text-center">Profile</th>
                        </tr>
                    </thead>

                    <tbody id="notFollowingTable"></tbody>

                </table>

            </div>

            <nav aria-label="Table pagination" class="mt-3">
                <ul class="pagination justify-content-center" id="pagination"></ul>
            </nav>

        </div>

    </div>

</div>

@section Scripts {

    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const form = document.getElementById("uploadForm");
            const tableBody = document.getElementById("notFollowingTable");
            const pagination = document.getElementById("pagination");

            const followersCount = document.getElementById("followersCount");
            const followingCount = document.getElementById("followingCount");
            const notFollowingBackCount = document.getElementById("NotfollowingBackCount");

            const rowsPerPage = 15;
            const maxPageLinks = 5;

            let allUsers = [];
            let currentPage = 1;

            const instagramIcon = '@Url.Content("~/resources/img/instagram.png")';

            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                const followersFile = document.getElementById("followerFile").files[0];
                const followingFile = document.getElementById("followingFile").files[0];
                
                if (!followersFile || !followingFile) {
                    alert("Please select both Followers and Following JSON files.");
                    return;
                }

                const formData = new FormData();
                formData.append("followersFile", followersFile);
                formData.append("followingFile", followingFile);

                const response = await fetch("https://localhost:7057/api/follow-analysis", {
                    method: "POST",
                    body: formData
                });

                if (!response.ok) {
                    throw new Error(`API error: ${response.status}`);
                }

                const result = await response.json();

                followersCount.textContent = result.followersCount;
                followingCount.textContent = result.followingCount;
                notFollowingBackCount.textContent = result.notFollowingBackCount;
                
                if (!result || !Array.isArray(result.usersNotFollowingBack)) {
                    alert("Unexpected API response format.");
                    return;
                }

                allUsers = result.usersNotFollowingBack;

                currentPage = 1;

                renderTable();
                renderPagination();
            });


            function renderTable() {
                tableBody.innerHTML = "";

                const start = (currentPage - 1) * rowsPerPage;
                const end = start + rowsPerPage;

                const pageUsers = allUsers.slice(start, end);

                let rows = "";

                pageUsers.forEach(user => {

                    const profileUrl = `https://www.instagram.com/${user}`;

                    rows += `
                    <tr>
                        <td class="text-center">${user}</td>
                        <td class="text-center">
                            <a href="${profileUrl}" target="_blank">
                                <img src="${instagramIcon}" width="16" height="16">
                            </a>
                        </td>
                    </tr>
                    `;

                });
                tableBody.innerHTML = rows;
               } 

            function renderPagination() {
                pagination.innerHTML = "";

                const totalPages = Math.ceil(allUsers.length / rowsPerPage);

                let startPage = Math.max(1, currentPage - Math.floor(maxPageLinks / 2));
                let endPage = startPage + maxPageLinks - 1;

                if (endPage > totalPages) {
                    endPage = totalPages;
                    startPage = Math.max(1, endPage - maxPageLinks + 1);
                }

                const prevItem = document.createElement("li");
                prevItem.className = `page-item ${currentPage === 1 ? "disabled" : ""}`;
                prevItem.innerHTML = `<a class="page-link" href="#">Previous</a>`;

                prevItem.addEventListener("click", e => {

                    e.preventDefault();

                    if (currentPage > 1) {
                        currentPage--;
                        renderTable();
                        renderPagination();
                    }

                });

                pagination.appendChild(prevItem);

                for (let i = startPage; i <= endPage; i++) {

                    const li = document.createElement("li");

                    li.className = `page-item ${i === currentPage ? "active" : ""}`;

                    li.innerHTML = `<a class="page-link" href="#">${i}</a>`;

                    li.addEventListener("click", e => {

                        e.preventDefault();

                        currentPage = i;

                        renderTable();
                        renderPagination();

                    });

                    pagination.appendChild(li);

                }

                const nextItem = document.createElement("li");
                nextItem.className = `page-item ${currentPage === totalPages ? "disabled" : ""}`;
                nextItem.innerHTML = `<a class="page-link" href="#">Next</a>`;

                nextItem.addEventListener("click", e => {

                    e.preventDefault();

                    if (currentPage < totalPages) {
                        currentPage++;
                        renderTable();
                        renderPagination();
                    }
                });
                pagination.appendChild(nextItem);
            }
        });
    </script>
}